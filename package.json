{
  "name": "engine",
  "type": "module",
  "imports": {
    "#3rdparty/*": "./src/3rdparty/*",
    "#jagex/*": "./src/jagex/*",
    "#/*": "./src/*"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bun": "latest",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.14.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "kysely": "^0.27.4",
    "lzma-native": "^8.0.6"
  },
  "scripts": {
    "launch": "npm run ts-loader src/scripts/launch.ts",
    "start": "npm run ts-loader src/app.ts",
    "bun:start": "bun run src/app.ts",
    "ts-loader": "node --experimental-strip-types --experimental-transform-types"
  }
